# ─────────────────────────────────────────────────────────────────────────────
# Prometheus Labs — variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a `.env.local` y completa los valores.
# En Vercel: configura las mismas keys en Project Settings → Environment Variables.

# ── Resend (envío de leads del formulario al buzón comercial) ────────────────
# 1. Crea una cuenta en https://resend.com
# 2. Verifica tu dominio prometheuslabs.com.co (o usa el dominio de Resend para test)
# 3. Genera una API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# "Remitente" de los emails de leads.
# Para producción: usa una dirección de un dominio verificado en Resend.
# Para test rápido: el default "onboarding@resend.dev" funciona pero solo
# permite enviar a la dirección de la cuenta dueña de la API key.
RESEND_FROM="Prometheus Labs <leads@prometheuslabs.com.co>"

# ── Opcional: site URL para metadata ─────────────────────────────────────────
# En producción Vercel lo inyecta automáticamente.
# NEXT_PUBLIC_SITE_URL=https://prometheuslabs.com.co
